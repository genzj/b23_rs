#!/usr/bin/env bash
set -e

echo "Running pre-commit checks..."

echo "Checking and formatting HTML (Biome)..."
if [ -f "./biome" ]; then
  ./biome check --write src/index.html
elif command -v biome &> /dev/null; then
  biome check --write src/index.html
else
  echo "Biome not found. Please run ./setup-hooks.sh to install it."
  exit 1
fi

echo "Checking formatting..."
cargo fmt --check

echo "Running clippy..."
cargo clippy -- -D warnings

echo "Running tests..."
cargo test

echo "All checks passed!"
